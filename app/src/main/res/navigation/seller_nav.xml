<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/seller_nav"
    app:startDestination="@id/navigation_home">

    <fragment
        android:id="@+id/navigation_home"
        android:name="com.kutira.kushala.seller.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_seller_home" />

    <fragment
        android:id="@+id/navigation_products"
        android:name="com.kutira.kushala.seller.ProductsFragment"
        android:label="My Products"
        tools:layout="@layout/fragment_seller_products" />

    <fragment
        android:id="@+id/navigation_capacity"
        android:name="com.kutira.kushala.seller.CapacityFragment"
        android:label="Capacity"
        tools:layout="@layout/fragment_seller_capacity" />

    <fragment
        android:id="@+id/navigation_profile"
        android:name="com.kutira.kushala.seller.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_seller_profile" />
</navigation>